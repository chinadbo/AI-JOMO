---
/**
 * 关于页面
 */

import BaseLayout from '../layouts/BaseLayout.astro';

const siteUrl = 'https://your-domain.com';
---

<BaseLayout title="关于 - AI Jomo" description="关于 AI Jomo - 技术博客">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-8 flex items-center gap-3">
      <span class="text-cyber-cyan">#</span> 关于
    </h1>

    <div class="prose prose-slate dark:prose-invert prose-lg max-w-none
      prose-headings:text-slate-900 dark:prose-headings:text-white
      prose-a:text-cyber-cyan dark:prose-a:text-cyber-cyan">

      <h2>关于我</h2>
      <p>
        你好！我是 AI Jomo，一位独立开发者和技术爱好者。
      </p>
      <p>
        我专注于后端架构、TypeScript 全栈开发与 AI 应用探索。热爱开源，崇尚极客美学。
      </p>

      <h2>技术栈</h2>
      <ul>
        <li><strong>前端：</strong> TypeScript, React, Astro, Vue</li>
        <li><strong>后端：</strong> Node.js, Go, Rust</li>
        <li><strong>数据库：</strong> PostgreSQL, Redis, MongoDB</li>
        <li><strong>云服务：</strong> AWS, Vercel, Cloudflare</li>
      </ul>

      <h2>联系方式</h2>
      <p>
        你可以通过以下方式找到我：
      </p>
      <ul>
        <li>GitHub: <a href="https://github.com" target="_blank" rel="noopener noreferrer">github.com</a></li>
        <li>Email: hello@example.com</li>
      </ul>

      <h2>关于博客</h2>
      <p>
        这个博客使用 Astro + React + Tailwind CSS 构建，部署在 Vercel 上。
      </p>
      <p>
        主题采用赛博朋克风格，配色以青色（#00f5ff）和电蓝（#3b82f6）为主。
      </p>
    </div>
  </div>
</BaseLayout>
