---
/**
 * About Page
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About - Ioodu's Blog" description="Ioodu - AI & Software Engineer specializing in Full Stack Architecture, Frontend Engineering, and AI/ML Applications">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <!-- Header -->
    <div class="mb-12">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-cyber-cyan/20 to-electric-blue/20 border border-cyber-cyan/30 flex items-center justify-center">
          <span class="text-2xl font-bold text-cyber-cyan">I</span>
        </div>
        <div>
          <h1 class="text-3xl font-bold text-slate-900 dark:text-white">Ioodu</h1>
          <p class="text-slate-500 text-sm">AI & Software Engineer</p>
        </div>
      </div>
      <div class="flex flex-wrap gap-2">
        <span class="px-3 py-1 rounded-full bg-cyber-cyan/10 text-cyber-cyan text-sm border border-cyber-cyan/20">Full Stack Architect</span>
        <span class="px-3 py-1 rounded-full bg-purple-500/10 text-purple-400 text-sm border border-purple-500/20">Frontend Specialist</span>
        <span class="px-3 py-1 rounded-full bg-green-500/10 text-green-400 text-sm border border-green-500/20">AI/ML Engineer</span>
      </div>
    </div>

    <div class="prose prose-slate dark:prose-invert prose-lg max-w-none">
      <!-- Intro -->
      <div class="bg-slate-50 dark:bg-slate-800/50 rounded-xl p-6 border border-slate-200 dark:border-slate-700 not-prose mb-8">
        <p class="text-slate-700 dark:text-slate-300 leading-relaxed mb-0">
          Passionate about building <span class="text-cyber-cyan font-medium">intelligent systems</span> and <span class="text-electric-blue font-medium">beautiful user experiences</span>.
          I specialize in <strong>Full Stack Architecture</strong> with a focus on <strong>Frontend Engineering</strong> and <strong>AI/ML Applications</strong>.
        </p>
      </div>

      <p>
        With expertise spanning modern web technologies to systems programming, I bridge the gap between
        cutting-edge AI capabilities and production-ready software architecture. I believe in writing code that is
        performant, maintainable, and user-centric.
      </p>

      <h2>What I Do</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 not-prose mb-8">
        <div class="p-4 rounded-lg bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700">
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg bg-blue-500/10 flex items-center justify-center">
              <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-slate-900 dark:text-white mb-1">Frontend Architecture</h3>
              <p class="text-sm text-slate-600 dark:text-slate-400">Building scalable React applications with TypeScript, Astro, and modern tooling</p>
            </div>
          </div>
        </div>
        <div class="p-4 rounded-lg bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700">
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg bg-green-500/10 flex items-center justify-center">
              <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-slate-900 dark:text-white mb-1">AI/ML Integration</h3>
              <p class="text-sm text-slate-600 dark:text-slate-400">Developing intelligent features using Python, LLMs, and machine learning pipelines</p>
            </div>
          </div>
        </div>
        <div class="p-4 rounded-lg bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700">
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg bg-purple-500/10 flex items-center justify-center">
              <svg class="w-4 h-4 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"></path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-slate-900 dark:text-white mb-1">Full Stack Development</h3>
              <p class="text-sm text-slate-600 dark:text-slate-400">End-to-end system design from database to user interface</p>
            </div>
          </div>
        </div>
        <div class="p-4 rounded-lg bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700">
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg bg-orange-500/10 flex items-center justify-center">
              <svg class="w-4 h-4 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-slate-900 dark:text-white mb-1">Systems Programming</h3>
              <p class="text-sm text-slate-600 dark:text-slate-400">Performance-critical components in Rust and Go</p>
            </div>
          </div>
        </div>
      </div>

      <h2>Tech Stack</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 not-prose mt-4">
        <div class="bg-slate-100 dark:bg-slate-800 p-4 rounded-lg border border-slate-200 dark:border-slate-700">
          <h3 class="text-cyber-cyan font-semibold mb-2 flex items-center gap-2">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path></svg>
            Frontend & UI
          </h3>
          <div class="flex flex-wrap gap-2">
            <span class="px-2 py-1 rounded bg-blue-500/20 text-blue-300 text-xs">TypeScript</span>
            <span class="px-2 py-1 rounded bg-cyan-500/20 text-cyan-300 text-xs">React</span>
            <span class="px-2 py-1 rounded bg-orange-500/20 text-orange-300 text-xs">Astro</span>
            <span class="px-2 py-1 rounded bg-slate-500/20 text-slate-300 text-xs">Next.js</span>
            <span class="px-2 py-1 rounded bg-sky-500/20 text-sky-300 text-xs">Tailwind CSS</span>
          </div>
        </div>
        <div class="bg-slate-100 dark:bg-slate-800 p-4 rounded-lg border border-slate-200 dark:border-slate-700">
          <h3 class="text-green-400 font-semibold mb-2 flex items-center gap-2">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2a10 10 0 100 20 10 10 0 000-20zm0 18a8 8 0 110-16 8 8 0 010 16zm-1-13h2v6h-2zm0 8h2v2h-2z"></path></svg>
            AI & Machine Learning
          </h3>
          <div class="flex flex-wrap gap-2">
            <span class="px-2 py-1 rounded bg-yellow-500/20 text-yellow-300 text-xs">Python</span>
            <span class="px-2 py-1 rounded bg-orange-500/20 text-orange-300 text-xs">PyTorch</span>
            <span class="px-2 py-1 rounded bg-orange-500/20 text-orange-300 text-xs">TensorFlow</span>
            <span class="px-2 py-1 rounded bg-green-500/20 text-green-300 text-xs">LLMs</span>
            <span class="px-2 py-1 rounded bg-slate-500/20 text-slate-300 text-xs">OpenAI API</span>
          </div>
        </div>
        <div class="bg-slate-100 dark:bg-slate-800 p-4 rounded-lg border border-slate-200 dark:border-slate-700">
          <h3 class="text-purple-400 font-semibold mb-2 flex items-center gap-2">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"></path></svg>
            Backend & Systems
          </h3>
          <div class="flex flex-wrap gap-2">
            <span class="px-2 py-1 rounded bg-green-500/20 text-green-300 text-xs">Node.js</span>
            <span class="px-2 py-1 rounded bg-orange-500/20 text-orange-300 text-xs">Rust</span>
            <span class="px-2 py-1 rounded bg-blue-500/20 text-blue-300 text-xs">Go</span>
            <span class="px-2 py-1 rounded bg-blue-500/20 text-blue-300 text-xs">PostgreSQL</span>
            <span class="px-2 py-1 rounded bg-red-500/20 text-red-300 text-xs">Redis</span>
          </div>
        </div>
        <div class="bg-slate-100 dark:bg-slate-800 p-4 rounded-lg border border-slate-200 dark:border-slate-700">
          <h3 class="text-sky-400 font-semibold mb-2 flex items-center gap-2">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"></path></svg>
            Cloud & DevOps
          </h3>
          <div class="flex flex-wrap gap-2">
            <span class="px-2 py-1 rounded bg-orange-500/20 text-orange-300 text-xs">AWS</span>
            <span class="px-2 py-1 rounded bg-slate-500/20 text-slate-300 text-xs">Vercel</span>
            <span class="px-2 py-1 rounded bg-orange-500/20 text-orange-300 text-xs">Cloudflare</span>
            <span class="px-2 py-1 rounded bg-blue-500/20 text-blue-300 text-xs">Docker</span>
            <span class="px-2 py-1 rounded bg-gray-500/20 text-gray-300 text-xs">CI/CD</span>
          </div>
        </div>
      </div>

      <h2 class="mt-8">Areas of Focus</h2>
      <ul>
        <li><strong>AI-Native Applications:</strong> Building products that leverage LLMs and machine learning at their core</li>
        <li><strong>Developer Tools:</strong> Creating CLI tools, VS Code extensions, and automation workflows</li>
        <li><strong>Performance Engineering:</strong> Optimizing web applications for speed and user experience</li>
        <li><strong>Technical Writing:</strong> Sharing knowledge through documentation, blog posts, and open source</li>
      </ul>

      <h2>Philosophy</h2>
      <blockquote class="border-l-4 border-cyber-cyan pl-4 italic bg-slate-50 dark:bg-slate-800/30 py-2 rounded-r">
        "Code is read more often than it is written."
      </blockquote>
      <p>
        I believe in writing clean, well-documented code that tells a story. Whether it's a complex AI pipeline
        or a simple React component, I strive for clarity and maintainability. I'm an advocate for open source
        and enjoy geek aesthetics in both code and design.
      </p>

      <h2>Contact & Links</h2>
      <div class="flex flex-wrap gap-3 not-prose">
        <a href="https://github.com/chinadbo" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2 bg-slate-100 dark:bg-slate-800 rounded-lg text-slate-700 dark:text-slate-300 hover:bg-cyber-cyan/10 hover:text-cyber-cyan transition-colors border border-slate-200 dark:border-slate-700">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path></svg>
          GitHub
        </a>
        <a href="mailto:chinadbo@gmail.com" class="inline-flex items-center gap-2 px-4 py-2 bg-slate-100 dark:bg-slate-800 rounded-lg text-slate-700 dark:text-slate-300 hover:bg-cyber-cyan/10 hover:text-cyber-cyan transition-colors border border-slate-200 dark:border-slate-700">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
          Email
        </a>
      </div>

      <h2>About This Blog</h2>
      <p>
        This blog is my digital garden where I share insights on software engineering, AI/ML, productivity,
        and the tools that power my workflow. It's built with <strong>Astro</strong>, <strong>React</strong>, and <strong>Tailwind CSS</strong>,
        deployed on Cloudflare Pages.
      </p>
      <p>
        The theme features a cyberpunk aesthetic with cyan (#00f5ff) accents, reflecting my love for
        technology and forward-thinking design.
      </p>
    </div>
  </div>
</BaseLayout>
