---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

{/* CONFIGURE: Replace all PLACEHOLDER_* values with actual Calendly event URLs */}
{/* See docs/external-services.md for setup instructions */}

<BaseLayout title="AI Engineering Services | Ioodu">
  <div class="page-container">
    <h1>AI Engineering Services</h1>

    <div class="services-grid">
      <div class="service-card">
        <h2>AI Architecture Audit</h2>
        <p class="price">$3,000</p>
        <p>2-week comprehensive review of your AI system architecture, with actionable recommendations.</p>
        <a href="https://calendly.com/chinadbo/ai-architecture-audit-discovery" class="btn" target="_blank" rel="noopener">Book Discovery Call</a>
      </div>

      <div class="service-card">
        <h2>RAG System Build</h2>
        <p class="price">$8,000</p>
        <p>4-week implementation of a production-ready RAG system tailored to your use case.</p>
        <a href="https://calendly.com/chinadbo/30min" class="btn" target="_blank" rel="noopener">Book Discovery Call</a>
      </div>

      <div class="service-card">
        <h2>Team AI Training</h2>
        <p class="price">$5,000</p>
        <p>2-day intensive workshop for your engineering team on AI best practices.</p>
        <a href="https://calendly.com/chinadbo/team-ai-training-discovery" class="btn" target="_blank" rel="noopener">Book Discovery Call</a>
      </div>

      <div class="service-card">
        <h2>Fractional AI Engineer</h2>
        <p class="price">$10,000/month</p>
        <p>Ongoing advisory and implementation support. Limited availability.</p>
        <a href="https://calendly.com/chinadbo/fractional-ai-engineer-application" class="btn" target="_blank" rel="noopener">Apply Now</a>
      </div>
    </div>
  </div>
</BaseLayout>
