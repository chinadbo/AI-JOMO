---
/**
 * Home Page
 * Hero Section with Terminal Effect, Latest Articles, Subscribe
 */

import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

// Get latest posts
const techPosts = (await getCollection('tech'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const gearPosts = (await getCollection('gear'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// Build search data
const searchItems = [
  ...techPosts.map((post) => ({
    title: post.data.title,
    url: `/tech/${post.id}`,
    description: post.data.description,
    tags: post.data.tags,
    type: 'article' as const,
    category: 'tech',
  })),
  ...gearPosts.map((post) => ({
    title: post.data.title,
    url: `/gear/${post.id}`,
    description: post.data.description,
    tags: post.data.tags,
    type: 'article' as const,
    category: 'gear',
  })),
];
---

<BaseLayout title="Ioodu's Blog - AI & Software Engineering" description="AI & Software Engineer specializing in Full Stack Architecture, Frontend Engineering, and AI/ML Applications. Thoughts on TypeScript, React, Rust, Go, and building intelligent systems." searchItems={searchItems}>
  <!-- Hero Section - Terminal Effect -->
  <section class="relative py-24 overflow-hidden">
    <!-- Background Grid -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(0,245,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(0,245,255,0.03)_1px,transparent_1px)] bg-[size:50px_50px]"></div>

    <div class="max-w-4xl mx-auto px-4 relative">
      <!-- Terminal Window -->
      <div class="bg-slate-900 rounded-xl border border-slate-800 overflow-hidden shadow-2xl shadow-cyber-cyan/5">
        <!-- Terminal Title Bar -->
        <div class="flex items-center gap-2 px-4 py-3 bg-slate-800/50 border-b border-slate-800">
          <div class="w-3 h-3 rounded-full bg-red-500"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
          <div class="w-3 h-3 rounded-full bg-green-500"></div>
          <span class="ml-4 text-xs text-slate-500 font-mono">guest@ioodu:~/blog</span>
        </div>

        <!-- Terminal Content -->
        <div class="p-6 font-mono text-sm">
          <div class="flex items-start gap-2">
            <span class="text-green-400">$</span>
            <div class="space-y-1 w-full">
              <!-- whoami -->
              <p class="text-cyber-cyan">whoami</p>
              <p class="text-slate-300">
                <span class="text-cyber-cyan">Ioodu</span>
                <span class="text-slate-500">|</span>
                <span class="text-electric-blue">AI & Software Engineer</span>
                <span class="text-slate-500">|</span>
                <span class="text-purple-400">Full Stack Architect</span>
              </p>

              <!-- cat about.txt -->
              <p class="text-slate-300 mt-4">cat about.txt</p>
              <p class="text-slate-400 max-w-2xl leading-relaxed">
                Building <span class="text-cyber-cyan">intelligent systems</span> and <span class="text-electric-blue">beautiful user experiences</span>.
                Specialized in <span class="text-purple-400">Frontend Architecture</span>, <span class="text-green-400">AI/ML integration</span>,
                and <span class="text-yellow-400">modern web technologies</span>.
              </p>

              <!-- echo $STACK -->
              <p class="text-slate-300 mt-4">echo $STACK</p>
              <p class="text-slate-400 flex flex-wrap gap-2">
                <span class="px-2 py-0.5 rounded bg-blue-500/10 text-blue-400 border border-blue-500/20">TypeScript</span>
                <span class="px-2 py-0.5 rounded bg-cyan-500/10 text-cyan-400 border border-cyan-500/20">React</span>
                <span class="px-2 py-0.5 rounded bg-orange-500/10 text-orange-400 border border-orange-500/20">Astro</span>
                <span class="px-2 py-0.5 rounded bg-orange-500/10 text-orange-400 border border-orange-500/20">Rust</span>
                <span class="px-2 py-0.5 rounded bg-blue-500/10 text-blue-400 border border-blue-500/20">Go</span>
                <span class="px-2 py-0.5 rounded bg-yellow-500/10 text-yellow-400 border border-yellow-500/20">Python</span>
                <span class="px-2 py-0.5 rounded bg-green-500/10 text-green-400 border border-green-500/20">AI/ML</span>
              </p>

              <!-- Current Focus -->
              <p class="text-slate-300 mt-4">ps aux | grep focus</p>
              <div class="text-slate-400 text-xs space-y-1">
                <p><span class="text-green-400">●</span> Architecting scalable frontend systems</p>
                <p><span class="text-green-400">●</span> Integrating LLMs into production applications</p>
                <p><span class="text-green-400">●</span> Building AI-native developer tools</p>
              </div>

              <!-- Cursor -->
              <p class="text-green-400 mt-6 animate-pulse">_<span class="ml-1 text-slate-500 text-xs">awaiting input...</span></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Articles -->
  <section class="max-w-6xl mx-auto px-4 py-12">
    <!-- Tech Articles -->
    <div class="mb-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white flex items-center gap-3">
          <span class="text-cyber-cyan">#</span> Tech Articles
        </h2>
        <a href="/tech" class="text-sm text-slate-500 hover:text-cyber-cyan transition-colors">
          View all →
        </a>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {techPosts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            cover={post.data.cover}
            url={`/tech/${post.id}`}
            category="tech"
            readingTime={post.data.readingTime}
          />
        ))}
      </div>

      {techPosts.length === 0 && (
        <p class="text-center text-slate-500 py-12">No tech articles yet</p>
      )}
    </div>

    <!-- Gear Reviews -->
    <div>
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white flex items-center gap-3">
          <span class="text-electric-blue">#</span> Gear Reviews
        </h2>
        <a href="/gear" class="text-sm text-slate-500 hover:text-electric-blue transition-colors">
          View all →
        </a>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {gearPosts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            cover={post.data.cover}
            url={`/gear/${post.id}`}
            category="gear"
            rating={post.data.rating}
          />
        ))}
      </div>

      {gearPosts.length === 0 && (
        <p class="text-center text-slate-500 py-12">No gear reviews yet</p>
      )}
    </div>
  </section>

  <!-- Subscribe -->
  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="glass rounded-xl p-8 text-center">
      <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-4">
        Stay Updated
      </h3>
      <p class="text-slate-600 dark:text-slate-400 mb-6">
        Subscribe via RSS to get the latest articles
      </p>
      <a
        href="/rss.xml"
        class="inline-flex items-center gap-2 px-6 py-3 bg-cyber-cyan/10 text-cyber-cyan rounded-lg hover:bg-cyber-cyan/20 transition-colors font-medium"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z"/>
        </svg>
        Subscribe RSS
      </a>
    </div>
  </section>
</BaseLayout>
