---
/**
 * 首页
 * 包含：Hero Section 打字机效果、最新文章列表、订阅入口
 */

import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

// 获取最新文章
const techPosts = (await getCollection('tech'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const gearPosts = (await getCollection('gear'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// 构建搜索数据
const searchItems = [
  ...techPosts.map((post) => ({
    title: post.data.title,
    url: `/tech/${post.id}`,
    description: post.data.description,
    tags: post.data.tags,
    type: 'article' as const,
    category: 'tech',
  })),
  ...gearPosts.map((post) => ({
    title: post.data.title,
    url: `/gear/${post.id}`,
    description: post.data.description,
    tags: post.data.tags,
    type: 'article' as const,
    category: 'gear',
  })),
];
---

<BaseLayout title="AI Jomo - 技术博客" description="AI Jomo 的技术博客 - 探索编程、架构与生活" searchItems={searchItems}>
  <!-- Hero Section - 终端打字机效果 -->
  <section class="relative py-24 overflow-hidden">
    <!-- 背景网格 -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(0,245,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(0,245,255,0.03)_1px,transparent_1px)] bg-[size:50px_50px]"></div>

    <div class="max-w-4xl mx-auto px-4 relative">
      <!-- 终端窗口 -->
      <div class="bg-slate-900 rounded-xl border border-slate-800 overflow-hidden shadow-2xl shadow-cyber-cyan/5">
        <!-- 终端标题栏 -->
        <div class="flex items-center gap-2 px-4 py-3 bg-slate-800/50 border-b border-slate-800">
          <div class="w-3 h-3 rounded-full bg-red-500"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
          <div class="w-3 h-3 rounded-full bg-green-500"></div>
          <span class="ml-4 text-xs text-slate-500 font-mono">guest@ai-jomo:~/blog</span>
        </div>

        <!-- 终端内容 -->
        <div class="p-6 font-mono text-sm">
          <div class="flex items-start gap-2">
            <span class="text-green-400">$</span>
            <div class="space-y-1">
              <p class="text-cyber-cyan">whoami</p>
              <p class="text-slate-300">AI Jomo | 独立开发者 | 技术爱好者</p>
              <p class="text-slate-300 mt-4">cat about.txt</p>
              <p class="text-slate-400 max-w-lg">
                专注于后端架构、TypeScript 全栈开发与 AI 应用探索。热爱开源，崇尚极客美学。
              </p>
              <p class="text-slate-300 mt-4">echo $STACK</p>
              <p class="text-slate-400">
                <span class="text-electric-blue">TypeScript</span> · <span class="text-electric-blue">React</span> · <span class="text-electric-blue">Astro</span> · <span class="text-electric-blue">Rust</span> · <span class="text-electric-blue">Go</span>
              </p>
              <p class="text-green-400 mt-6 animate-pulse">_</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 最新文章 -->
  <section class="max-w-6xl mx-auto px-4 py-12">
    <!-- 技术文章 -->
    <div class="mb-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white flex items-center gap-3">
          <span class="text-cyber-cyan">#</span> 技术文章
        </h2>
        <a href="/tech" class="text-sm text-slate-500 hover:text-cyber-cyan transition-colors">
          查看全部 →
        </a>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {techPosts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            cover={post.data.cover}
            url={`/tech/${post.id}`}
            category="tech"
          />
        ))}
      </div>

      {techPosts.length === 0 && (
        <p class="text-center text-slate-500 py-12">暂无技术文章</p>
      )}
    </div>

    <!-- 装备文章 -->
    <div>
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white flex items-center gap-3">
          <span class="text-electric-blue">#</span> 装备分享
        </h2>
        <a href="/gear" class="text-sm text-slate-500 hover:text-electric-blue transition-colors">
          查看全部 →
        </a>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {gearPosts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            cover={post.data.cover}
            url={`/gear/${post.id}`}
            category="gear"
            rating={post.data.rating}
          />
        ))}
      </div>

      {gearPosts.length === 0 && (
        <p class="text-center text-slate-500 py-12">暂无装备分享</p>
      )}
    </div>
  </section>

  <!-- 订阅入口 -->
  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="glass rounded-xl p-8 text-center">
      <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-4">
        订阅更新
      </h3>
      <p class="text-slate-600 dark:text-slate-400 mb-6">
        通过 RSS 订阅获取最新文章推送
      </p>
      <a
        href="/rss.xml"
        class="inline-flex items-center gap-2 px-6 py-3 bg-cyber-cyan/10 text-cyber-cyan rounded-lg hover:bg-cyber-cyan/20 transition-colors font-medium"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z"/>
        </svg>
        订阅 RSS
      </a>
    </div>
  </section>
</BaseLayout>
