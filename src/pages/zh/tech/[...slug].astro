---
/**
 * Tech Article Detail (Chinese)
 */
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ReadingProgress from '../../../components/ReadingProgress.astro';
import TableOfContents from '../../../components/TableOfContents.astro';
import RelatedPosts from '../../../components/RelatedPosts.astro';
import PageNavigation from '../../../components/PageNavigation.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import StructuredData from '../../../components/StructuredData.astro';
import Giscus from '../../../components/Giscus.astro';

export async function getStaticPaths() {
  const posts = await getCollection('tech');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const searchItems = [{
  title: post.data.title,
  url: `/zh/tech/${post.id}`,
  description: post.data.description,
  tags: post.data.tags,
  type: 'article' as const,
  category: 'tech',
}];

// Get prev/next posts
const allPosts = await getCollection('tech');
const sortedPosts = allPosts.filter(p => !p.data.draft).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const currentIndex = sortedPosts.findIndex((p) => p.id === post.id);
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;

const formatDate = (date: Date) => new Date(date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
const readingTime = post.data.readingTime || 5;

// Breadcrumb items
const breadcrumbItems = [
  { label: '首页', url: '/zh' },
  { label: '技术', url: '/zh/tech' },
  { label: post.data.title, url: `/zh/tech/${post.id}`, isCurrent: true },
];

// Estimate word count for structured data
const wordCount = post.body ? post.body.split(/\s+/).length : 0;
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  type="article"
  publishedTime={post.data.pubDate}
  modifiedTime={post.data.updatedDate}
  author={post.data.author}
  tags={post.data.tags}
  canonical={`/zh/tech/${post.id}`}
  searchItems={searchItems}
>
  <!-- Article Structured Data -->
  <StructuredData
    type="BlogPosting"
    data={{
      title: post.data.title,
      description: post.data.description,
      url: `/zh/tech/${post.id}`,
      pubDate: post.data.pubDate,
      updatedDate: post.data.updatedDate,
      tags: post.data.tags,
      category: 'tech',
      wordCount,
    }}
  />
  <StructuredData
    type="BreadcrumbList"
    data={{ items: breadcrumbItems.map(({ label, url }) => ({ name: label, url })) }}
  />

  <ReadingProgress />
  <TableOfContents headings={headings} />

  <article class="max-w-3xl mx-auto px-4 pt-12 pb-20">
    <!-- Breadcrumbs -->
    <Breadcrumbs items={breadcrumbItems} />
    <header class="mb-8">
      <div class="flex flex-wrap gap-2 mb-4">
        {post.data.categories?.map((category) => (
          <span class="text-xs font-medium px-2 py-1 rounded bg-cyber-cyan/10 text-cyber-cyan uppercase tracking-wide">{category}</span>
        ))}
      </div>

      <h1 class="font-display text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-4 leading-tight">{post.data.title}</h1>

      <p class="text-lg text-slate-600 dark:text-slate-400 mb-6">{post.data.description}</p>

      <div class="flex flex-wrap items-center gap-4 text-sm text-slate-500">
        <span class="font-medium text-slate-700 dark:text-slate-300">{post.data.author || 'Ioodu'}</span>
        <span>·</span>
        <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
        <span>·</span>
        <span class="flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          {readingTime} 分钟阅读
        </span>
      </div>

      <div class="flex flex-wrap gap-2 mt-4">
        {post.data.tags.map((tag) => <span class="tag">#{tag}</span>)}
      </div>
    </header>

    {post.data.cover && <img src={post.data.cover} alt={post.data.title} class="w-full aspect-video object-cover rounded-xl mb-8" />}

    <div class="prose prose-lg dark:prose-invert max-w-none">
      <Content />
    </div>

    {/* Related Posts */}
    <RelatedPosts currentPost={post} currentLang="zh" limit={3} />

    {/* Page Navigation */}
    <PageNavigation
      prev={prevPost ? { title: prevPost.data.title, url: `/zh/tech/${prevPost.id}` } : undefined}
      next={nextPost ? { title: nextPost.data.title, url: `/zh/tech/${nextPost.id}` } : undefined}
      currentLang="zh"
    />

    <Giscus />
  </article>
</BaseLayout>
