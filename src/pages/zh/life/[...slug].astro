---
/**
 * Life Detail Page (Chinese)
 */
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ReadingProgress from '../../../components/ReadingProgress.astro';
import TableOfContents from '../../../components/TableOfContents.astro';
import RelatedPosts from '../../../components/RelatedPosts.astro';
import PageNavigation from '../../../components/PageNavigation.astro';
import Giscus from '../../../components/Giscus.astro';

export async function getStaticPaths() {
  const posts = await getCollection('life');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const searchItems = [
  {
    title: post.data.title,
    url: `/zh/life/${post.id}`,
    description: post.data.description,
    tags: post.data.tags,
    type: 'article' as const,
    category: 'life',
  },
];

// Get prev/next posts
const allPosts = await getCollection('life');
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const currentIndex = sortedPosts.findIndex((p) => p.id === post.id);
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;

const formatDate = (date: Date) => {
  return new Date(date).toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};
---

<BaseLayout
  title={`${post.data.title} - Ioodu's Blog`}
  description={post.data.description}
  searchItems={searchItems}
>
  <ReadingProgress />
  <TableOfContents headings={headings} />

  <article class="max-w-3xl mx-auto px-4 pt-12 pb-20">
    {/* Header */}
    <header class="mb-8">
      {/* Tags */}
      <div class="flex flex-wrap gap-2 mb-4">
        {post.data.tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>

      {/* Title */}
      <h1 class="font-display text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-4 leading-tight">
        {post.data.title}
      </h1>

      {/* Meta */}
      <div class="flex flex-wrap items-center gap-4 text-sm text-slate-500">
        <time datetime={post.data.pubDate.toISOString()}>
          {formatDate(post.data.pubDate)}
        </time>
        {post.data.readingTime && (
          <>
            <span>·</span>
            <span>{post.data.readingTime} 分钟阅读</span>
          </>
        )}
        {post.data.updatedDate && (
          <>
            <span>·</span>
            <span>更新于 {formatDate(post.data.updatedDate)}</span>
          </>
        )}
        {post.data.location && (
          <>
            <span>·</span>
            <span class="flex items-center gap-1">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              {post.data.location}
            </span>
          </>
        )}
      </div>
    </header>

    {/* Cover Image */}
    {post.data.cover && (
      <img
        src={post.data.cover}
        alt={post.data.title}
        class="w-full aspect-video object-cover rounded-xl mb-8"
      />
    )}

    {/* Photo Gallery */}
    {post.data.photos && post.data.photos.length > 0 && (
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-8">
        {post.data.photos.map((photo) => (
          <img
            src={photo}
            alt=""
            class="w-full aspect-square object-cover rounded-lg hover:scale-105 transition-transform cursor-pointer"
            loading="lazy"
          />
        ))}
      </div>
    )}

    {/* Content */}
    <div class="prose prose-lg dark:prose-invert max-w-none">
      <Content />
    </div>

    {/* Footer */}
    <footer class="mt-12 pt-8 border-t border-slate-200 dark:border-slate-800">
      <div class="flex items-center justify-between">
        <div class="text-sm text-slate-500">
          作者: <span class="text-slate-900 dark:text-slate-100">{post.data.author}</span>
        </div>
        <a
          href="/zh/life"
          class="text-sm text-cyber-cyan hover:underline"
        >
          ← 返回生活列表
        </a>
      </div>
    </footer>

    {/* Related Posts */}
    <RelatedPosts currentPost={post} currentLang="zh" limit={3} />

    {/* Page Navigation */}
    <PageNavigation
      prev={prevPost ? { title: prevPost.data.title, url: `/zh/life/${prevPost.id}` } : undefined}
      next={nextPost ? { title: nextPost.data.title, url: `/zh/life/${nextPost.id}` } : undefined}
      currentLang="zh"
    />

    {/* Comments */}
    <Giscus />
  </article>
</BaseLayout>
