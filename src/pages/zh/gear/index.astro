---
/**
 * Gear Reviews List (Chinese)
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';

const posts = (await getCollection('gear')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const searchItems = posts.map((post) => ({
  title: post.data.title,
  url: `/zh/gear/${post.id}`,
  description: post.data.description,
  tags: post.data.tags,
  type: 'article' as const,
  category: 'gear',
}));
---

<BaseLayout title="装备评测 - Ioodu's Blog" description="EDC、数码装备与产品评测" searchItems={searchItems}>
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="mb-12">
      <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-4 flex items-center gap-3">
        <span class="text-electric-blue">#</span> 装备评测
      </h1>
      <p class="text-slate-600 dark:text-slate-400">EDC、数码装备与产品评测</p>
    </div>

    {posts.length > 0 ? (
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post) => (
          <PostCard title={post.data.title} description={post.data.description} pubDate={post.data.pubDate} tags={post.data.tags} cover={post.data.cover} url={`/zh/gear/${post.id}`} category="gear" rating={post.data.rating} />
        ))}
      </div>
    ) : (
      <div class="text-center py-20">
        <p class="text-slate-500 mb-4">暂无评测</p>
        <a href="/zh/" class="text-electric-blue hover:underline">返回首页</a>
      </div>
    )}
  </div>
</BaseLayout>
