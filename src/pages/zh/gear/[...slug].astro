---
/**
 * Gear Review Detail (Chinese)
 */
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ReadingProgress from '../../../components/ReadingProgress.astro';
import TableOfContents from '../../../components/TableOfContents.astro';
import RelatedPosts from '../../../components/RelatedPosts.astro';
import PageNavigation from '../../../components/PageNavigation.astro';
import Giscus from '../../../components/Giscus.astro';

export async function getStaticPaths() {
  const posts = await getCollection('gear');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const searchItems = [{
  title: post.data.title,
  url: `/zh/gear/${post.id}`,
  description: post.data.description,
  tags: post.data.tags,
  type: 'article' as const,
  category: 'gear',
}];

// Get prev/next posts
const allPosts = await getCollection('gear');
const sortedPosts = allPosts.filter(p => !p.data.draft).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const currentIndex = sortedPosts.findIndex((p) => p.id === post.id);
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;

const formatDate = (date: Date) => new Date(date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={`${post.data.title} - Ioodu's Blog`} description={post.data.description} searchItems={searchItems}>
  <ReadingProgress />
  <TableOfContents headings={headings} />

  <article class="max-w-3xl mx-auto px-4 pt-12 pb-20">
    <header class="mb-8">
      <div class="flex flex-wrap gap-2 mb-4">
        {post.data.categories?.map((category) => <span class="text-xs font-medium px-2 py-1 rounded bg-electric-blue/10 text-electric-blue uppercase tracking-wide">{category}</span>)}
        {post.data.brand && <span class="text-xs font-medium px-2 py-1 rounded bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400">{post.data.brand}</span>}
      </div>

      <h1 class="font-display text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-4 leading-tight">{post.data.title}</h1>

      <p class="text-lg text-slate-600 dark:text-slate-400 mb-6">{post.data.description}</p>

      <div class="flex items-center justify-between flex-wrap gap-4">
        <div class="flex items-center gap-4 text-sm text-slate-500">
          <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
        </div>
        <div class="flex items-center gap-3">
          <div class="flex">
            {Array.from({ length: 5 }, (_, i) => <span class={i < post.data.rating ? 'text-yellow-400 text-xl' : 'text-slate-300 dark:text-slate-600 text-xl'}>★</span>)}
          </div>
          <span class="text-sm text-slate-500">{post.data.rating}/5</span>
        </div>
      </div>
    </header>

    {post.data.cover && <img src={post.data.cover} alt={post.data.title} class="w-full aspect-video object-cover rounded-xl mb-8" />}

    {post.data.purchaseLink && (
      <div class="mb-8 p-4 bg-electric-blue/10 rounded-xl">
        <a href={post.data.purchaseLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-electric-blue hover:underline font-medium">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          在 {post.data.brand || 'Amazon'} 查看 {post.data.price && `(${post.data.price})`}
        </a>
      </div>
    )}

    <div class="flex flex-wrap gap-2 mb-8">
      {post.data.tags.map((tag) => <span class="tag">#{tag}</span>)}
    </div>

    <div class="prose prose-lg dark:prose-invert max-w-none">
      <Content />
    </div>

    {/* Related Posts */}
    <RelatedPosts currentPost={post} currentLang="zh" limit={3} />

    {/* Page Navigation */}
    <PageNavigation
      prev={prevPost ? { title: prevPost.data.title, url: `/zh/gear/${prevPost.id}` } : undefined}
      next={nextPost ? { title: nextPost.data.title, url: `/zh/gear/${nextPost.id}` } : undefined}
      currentLang="zh"
    />

    <Giscus />
  </article>
</BaseLayout>
