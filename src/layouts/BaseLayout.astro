---
/**
 * Base Layout Component
 * Includes: Glassmorphism Navbar, ClientRouter Page Transitions, ThemeToggle, CommandPalette, SEO
 */

import { ClientRouter } from 'astro:transitions';
import { SEO } from 'astro-seo';
import ThemeToggle from '../components/ThemeToggle';
import CommandPalette from '../components/CommandPalette';
import { translations, type Language } from '../i18n';
import '../styles/global.css';

// Site configuration
const siteUrl = 'https://your-domain.com';

// Get language from URL path (e.g., /zh/about, /en/about)
// Default to 'en' if no language prefix
const pathname = Astro.url.pathname;
const langMatch = pathname.match(/^\/(zh|en)(\/|$)/);
const currentLang: Language = langMatch ? (langMatch[1] as Language) : 'en';

// Get translations for current language
const t = translations[currentLang];

// Props interface
interface Props {
  title: string;
  description?: string;
  searchItems?: Array<{
    title: string;
    url: string;
    description: string;
    tags: string[];
    type: 'article' | 'command';
    category?: string;
  }>;
}

const { title, description = 'A blog about programming, architecture, AI, and gear reviews.', searchItems = [] } = Astro.props;

// Navigation links with translations
const navLinks = [
  { href: `/${currentLang}/tech`, label: t.nav.tech },
  { href: `/${currentLang}/essays`, label: t.nav.essays },
  { href: `/${currentLang}/life`, label: t.nav.life },
  { href: `/${currentLang}/gear`, label: t.nav.gear },
  { href: `/${currentLang}/about`, label: t.nav.about },
];

// Update paths to include language prefix
const homePath = `/${currentLang}`;
const currentPath = pathname.replace(/^\/(zh|en)/, '') || '/';
---

<!DOCTYPE html>
<html lang={currentLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- SEO Configuration -->
    <SEO
      title={title}
      description={description}
      canonical={`${siteUrl}${pathname}`}
      openGraph={{
        basic: {
          title: title,
          url: `${siteUrl}${pathname}`,
          type: 'website',
          image: `${siteUrl}/og-image.png`,
        },
        optional: {
          locale: currentLang === 'zh' ? 'zh_CN' : 'en_US',
          siteName: "Ioodu's Blog",
        },
      }}
    />

    <!-- Page Transitions -->
    <ClientRouter />

    <!-- Initialize dark mode (prevent flash) -->
    <script is:inline>
      const stored = localStorage.getItem('theme');
      if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>

    <!-- Language detection for client-side -->
    <script is:inline>
      // Get language from URL or detect from browser
      function getLang() {
        const path = window.location.pathname;
        const match = path.match(/^\/(zh|en)(\/|$)/);
        if (match) return match[1];

        const browserLang = navigator.language.toLowerCase();
        if (browserLang.startsWith('zh')) return 'zh';
        return 'en';
      }

      // Store current language
      window.__lang__ = getLang();
    </script>
  </head>

  <body class="min-h-screen flex flex-col">
    <!-- Glassmorphism Navbar -->
    <header class="fixed top-0 left-0 right-0 z-40 glass">
      <nav class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
        <!-- Left: Logo -->
        <a href={homePath} class="flex items-center gap-2 group">
          <div class="w-8 h-8 relative">
            <div class="absolute inset-0 grid grid-cols-4 grid-rows-4 gap-0.5">
              <div class="col-start-1 row-start-2 bg-cyber-cyan"></div>
              <div class="col-start-4 row-start-2 bg-cyber-cyan"></div>
              <div class="col-start-2 row-start-3 col-span-2 bg-cyber-cyan"></div>
              <div class="col-start-1 row-start-4 bg-cyber-cyan"></div>
              <div class="col-start-4 row-start-4 bg-cyber-cyan"></div>
            </div>
          </div>
          <span class="font-mono text-lg font-bold text-slate-900 dark:text-white group-hover:text-cyber-cyan transition-colors">
            Ioodu
          </span>
        </a>

        <!-- Center: Navigation Links -->
        <ul class="flex items-center gap-6">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="font-medium text-slate-700 dark:text-slate-300 hover:text-cyber-cyan dark:hover:text-cyber-cyan transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <!-- Right: Language Toggle + Theme Toggle + Command Palette -->
        <div class="flex items-center gap-2">
          <!-- Language Toggle -->
          <a
            href={currentLang === 'en' ? `/zh${currentPath === '/' ? '' : currentPath}` : `/en${currentPath === '/' ? '' : currentPath}`}
            class="px-2 py-1 text-xs font-medium text-slate-500 hover:text-cyber-cyan transition-colors"
          >
            {currentLang === 'en' ? '中文' : 'EN'}
          </a>

          <!-- Command Palette Trigger -->
          <button
            id="cmd-k-trigger"
            class="hidden md:flex items-center gap-2 px-3 py-1.5 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-500 hover:text-cyber-cyan transition-colors text-sm"
          >
            <span class="text-xs">{currentLang === 'en' ? 'Search' : '搜索'}</span>
            <kbd class="px-1.5 py-0.5 rounded bg-slate-200 dark:bg-slate-700 text-xs">⌘K</kbd>
          </button>

          <!-- Theme Toggle -->
          <ThemeToggle client:load />
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <main class="flex-1 pt-16">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-slate-200 dark:border-slate-800 mt-20">
      <div class="max-w-6xl mx-auto px-4 py-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-4">
          <!-- Copyright -->
          <p class="text-sm text-slate-500">
            &copy; {new Date().getFullYear()} {t.footer.copyright}
          </p>

          <!-- Links -->
          <div class="flex items-center gap-4">
            <a
              href={`/${currentLang}/rss.xml`}
              class="text-sm text-slate-500 hover:text-cyber-cyan transition-colors"
            >
              RSS
            </a>
            <a
              href="https://github.com/chinadbo/AI-JOMO"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-slate-500 hover:text-cyber-cyan transition-colors"
            >
              GitHub
            </a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Command Palette -->
    <CommandPalette client:load items={searchItems} />

    <!-- Command Palette Trigger Script -->
    <script>
      document.getElementById('cmd-k-trigger')?.addEventListener('click', () => {
        window.dispatchEvent(new KeyboardEvent('keydown', { key: 'k', metaKey: true }));
      });
    </script>
  </body>
</html>
