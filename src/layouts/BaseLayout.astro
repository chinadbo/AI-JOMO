---
/**
 * Base Layout Component
 * Includes: Glassmorphism Navbar, ClientRouter Page Transitions, ThemeToggle, CommandPalette, Enhanced SEO
 */

import { ClientRouter } from 'astro:transitions';
import ThemeToggle from '../components/ThemeToggle';
import CommandPalette from '../components/CommandPalette';
import SEO from '../components/SEO.astro';
import StructuredData from '../components/StructuredData.astro';
import '../styles/global.css';

// Site configuration
const siteUrl = 'https://blog.ioodu.com';
const pathname = Astro.url.pathname;

// Props interface
interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  modifiedTime?: Date;
  author?: string;
  tags?: string[];
  canonical?: string;
  searchItems?: Array<{
    title: string;
    url: string;
    description: string;
    tags: string[];
    type: 'article' | 'command';
    category?: string;
  }>;
  noindex?: boolean;
}

const {
  title,
  description = 'AI & Software Engineer specializing in Full Stack Architecture, Frontend Engineering, and AI/ML Applications. Thoughts on TypeScript, React, Rust, Go, Python, and building intelligent systems.',
  image,
  type = 'website',
  publishedTime,
  modifiedTime,
  author,
  tags = [],
  canonical,
  searchItems = [],
  noindex = false,
} = Astro.props;

// Navigation links
const navLinks = [
  { href: '/tech', label: 'Tech' },
  { href: '/essays', label: 'Essays' },
  { href: '/life', label: 'Life' },
  { href: '/gear', label: 'Gear' },
  { href: '/about', label: 'About' },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Enhanced SEO -->
    <SEO
      title={title}
      description={description}
      image={image}
      type={type}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      author={author}
      tags={tags}
      canonical={canonical || pathname}
      noindex={noindex}
    />

    <!-- Website Structured Data -->
    <StructuredData type="WebSite" />

    <!-- Page Transitions -->
    <ClientRouter />

    <!-- Initialize dark mode (prevent flash) -->
    <script is:inline>
      const stored = localStorage.getItem('theme');
      if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>

  <body class="min-h-screen flex flex-col">
    <!-- Glassmorphism Navbar -->
    <header class="fixed top-0 left-0 right-0 z-40 glass" transition:persist>
      <nav class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
        <!-- Left: Logo -->
        <a href="/" class="flex items-center gap-2 group">
          <div class="w-8 h-8 relative">
            <div class="absolute inset-0 grid grid-cols-4 grid-rows-4 gap-0.5">
              <div class="col-start-1 row-start-2 bg-cyber-cyan"></div>
              <div class="col-start-4 row-start-2 bg-cyber-cyan"></div>
              <div class="col-start-2 row-start-3 col-span-2 bg-cyber-cyan"></div>
              <div class="col-start-1 row-start-4 bg-cyber-cyan"></div>
              <div class="col-start-4 row-start-4 bg-cyber-cyan"></div>
            </div>
          </div>
          <span class="font-mono text-lg font-bold text-slate-900 dark:text-white group-hover:text-cyber-cyan transition-colors">
            Ioodu
          </span>
        </a>

        <!-- Center: Navigation Links (Desktop) -->
        <ul class="hidden md:flex items-center gap-6">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="font-medium text-slate-700 dark:text-slate-300 hover:text-cyber-cyan dark:hover:text-cyber-cyan transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <!-- Right: Mobile Menu Button + Command Palette Trigger + Theme Toggle -->
        <div class="flex items-center gap-2">
          <!-- Mobile Menu Button -->
          <button
            id="mobile-menu-btn"
            class="md:hidden p-2 rounded-lg text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
            aria-label="Toggle menu"
            aria-expanded="false"
          >
            <svg id="menu-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
            <svg id="close-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
          <!-- Command Palette Trigger -->
          <button
            id="cmd-k-trigger"
            class="hidden md:flex items-center gap-2 px-3 py-1.5 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-500 hover:text-cyber-cyan transition-colors text-sm"
          >
            <span class="text-xs">Search</span>
            <kbd class="px-1.5 py-0.5 rounded bg-slate-200 dark:bg-slate-700 text-xs">⌘K</kbd>
          </button>

          <!-- Theme Toggle -->
          <ThemeToggle client:load />
        </div>
      </nav>
    </header>

    <!-- Mobile Navigation Menu -->
    <div
      id="mobile-menu"
      class="fixed inset-x-0 top-16 z-30 glass border-b border-slate-200 dark:border-slate-800 transform -translate-y-full transition-transform duration-300 ease-in-out md:hidden"
    >
      <nav class="max-w-6xl mx-auto px-4 py-4">
        <ul class="space-y-2">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="mobile-nav-link block py-3 px-4 rounded-lg font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 hover:text-cyber-cyan dark:hover:text-cyber-cyan transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <!-- Main Content -->
    <main class="flex-1 pt-16">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-slate-200 dark:border-slate-800 mt-20">
      <div class="max-w-6xl mx-auto px-4 py-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-4">
          <!-- Copyright -->
          <p class="text-sm text-slate-500">
            &copy; {new Date().getFullYear()} Ioodu. All rights reserved.
          </p>

          <!-- Links -->
          <div class="flex items-center gap-4">
            <a
              href="/rss.xml"
              class="text-sm text-slate-500 hover:text-cyber-cyan transition-colors"
            >
              RSS
            </a>
            <a
              href="https://github.com/chinadbo/AI-JOMO"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-slate-500 hover:text-cyber-cyan transition-colors"
            >
              GitHub
            </a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Command Palette -->
    <CommandPalette client:load items={searchItems} />

    <!-- Command Palette Trigger Script -->
    <script>
      // Expose global function to open command palette
      (window as any).openCommandPalette = () => {
        window.dispatchEvent(new CustomEvent('open-command-palette'));
      };

      document.getElementById('cmd-k-trigger')?.addEventListener('click', () => {
        (window as any).openCommandPalette();
      });

      // Mobile menu toggle
      (function() {
        const menuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        const menuIcon = document.getElementById('menu-icon');
        const closeIcon = document.getElementById('close-icon');
        const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');
        let isOpen = false;

        function toggleMenu() {
          isOpen = !isOpen;
          if (isOpen) {
            mobileMenu?.classList.remove('-translate-y-full');
            menuIcon?.classList.add('hidden');
            closeIcon?.classList.remove('hidden');
            menuBtn?.setAttribute('aria-expanded', 'true');
          } else {
            mobileMenu?.classList.add('-translate-y-full');
            menuIcon?.classList.remove('hidden');
            closeIcon?.classList.add('hidden');
            menuBtn?.setAttribute('aria-expanded', 'false');
          }
        }

        function closeMenu() {
          if (isOpen) {
            isOpen = false;
            mobileMenu?.classList.add('-translate-y-full');
            menuIcon?.classList.remove('hidden');
            closeIcon?.classList.add('hidden');
            menuBtn?.setAttribute('aria-expanded', 'false');
          }
        }

        menuBtn?.addEventListener('click', toggleMenu);

        // Close menu when clicking a link
        mobileNavLinks.forEach(link => {
          link.addEventListener('click', closeMenu);
        });

        // Close menu when clicking outside
        document.addEventListener('click', (e) => {
          if (isOpen && !mobileMenu?.contains(e.target as Node) && !menuBtn?.contains(e.target as Node)) {
            closeMenu();
          }
        });

        // Close menu on escape key
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && isOpen) {
            closeMenu();
          }
        });
      })();
    </script>
  </body>
</html>
