---
/**
 * Giscus 评论组件
 *
 * 配置步骤：
 * 1. 确保仓库已启用 Discussions: Settings -> General -> Discussions ✅
 * 2. 安装 Giscus App: https://github.com/apps/giscus
 * 3. 在仓库 Discussions 中创建 "Announcements" 分类（如果不存在）
 * 4. 验证 category-id 正确
 *
 * 当前配置：
 * - 仓库: chinadbo/AI-JOMO
 * - 评论映射: pathname（根据文章路径自动匹配）
 * - 主题: preferred_color_scheme（跟随系统偏好）
 */

// 获取当前语言
const pathname = Astro.url.pathname;
const langMatch = pathname.match(/^\/(zh|en)(\/|$)/);
const currentLang = langMatch ? langMatch[1] : 'zh';

// Giscus 配置 - 使用 title 映射更稳定
const giscusConfig = {
  repo: "chinadbo/AI-JOMO",
  repoId: "R_kgDORlCkXA",
  category: "Announcements",
  categoryId: "DIC_kwDORlCkXM4C4bYR",
  mapping: "pathname", // 改为 pathname 更稳定
  strict: "0",
  reactionsEnabled: "1",
  emitMetadata: "0",
  inputPosition: "bottom",
  theme: "preferred_color_scheme",
  lang: currentLang === 'zh' ? 'zh-CN' : 'en',
  loading: "lazy"
};
---
---

<div class="giscus-wrapper mt-12 pt-8 border-t border-slate-200 dark:border-slate-800" id="giscus-container">
  <h3 class="font-display text-lg font-semibold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
    <svg class="w-5 h-5 text-cyber-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
    </svg>
    {currentLang === 'zh' ? '评论' : 'Comments'}
  </h3>

  <!-- Error message container -->
  <div id="giscus-error" class="hidden p-4 rounded-lg bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 text-amber-800 dark:text-amber-200 text-sm">
    <p class="font-medium mb-2">{currentLang === 'zh' ? '评论功能配置中' : 'Comments temporarily unavailable'}</p>
    <p class="text-amber-700 dark:text-amber-300">
      {currentLang === 'zh'
        ? '正在配置评论系统。如果问题持续，请通过 GitHub Discussions 留言。'
        : 'Configuring comment system. Please use GitHub Discussions if the issue persists.'}
    </p>
    <a
      href={`https://github.com/chinadbo/AI-JOMO/discussions`}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1 mt-2 text-cyber-cyan hover:underline"
    >
      {currentLang === 'zh' ? '前往 GitHub Discussions' : 'Go to GitHub Discussions'}
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
      </svg>
    </a>
  </div>

  <script
    is:inline
    src="https://giscus.app/client.js"
    data-repo={giscusConfig.repo}
    data-repo-id={giscusConfig.repoId}
    data-category={giscusConfig.category}
    data-category-id={giscusConfig.categoryId}
    data-mapping={giscusConfig.mapping}
    data-strict={giscusConfig.strict}
    data-reactions-enabled={giscusConfig.reactionsEnabled}
    data-emit-metadata={giscusConfig.emitMetadata}
    data-input-position={giscusConfig.inputPosition}
    data-theme={giscusConfig.theme}
    data-lang={giscusConfig.lang}
    data-loading={giscusConfig.loading}
    crossorigin="anonymous"
    async
  ></script>

  <!-- Theme toggle support for Giscus -->
  <script is:inline>
    (function() {
      // Listen for theme changes
      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          if (mutation.attributeName === 'class') {
            const isDark = document.documentElement.classList.contains('dark');
            const iframe = document.querySelector('iframe.giscus-frame');
            if (iframe) {
              iframe.contentWindow?.postMessage(
                { giscus: { setConfig: { theme: isDark ? 'dark' : 'light' } } },
                'https://giscus.app'
              );
            }
          }
        });
      });

      observer.observe(document.documentElement, { attributes: true });

      // Handle Giscus errors
      window.addEventListener('message', function(e) {
        if (e.origin !== 'https://giscus.app') return;

        // Check for error message
        if (e.data && e.data.giscus && e.data.giscus.error) {
          console.error('Giscus error:', e.data.giscus.error);
          const errorDiv = document.getElementById('giscus-error');
          if (errorDiv) {
            errorDiv.classList.remove('hidden');
          }
        }
      });

      // Fallback: Show error if giscus doesn't load within 10 seconds
      setTimeout(function() {
        const iframe = document.querySelector('iframe.giscus-frame');
        const errorDiv = document.getElementById('giscus-error');
        if (!iframe && errorDiv) {
          errorDiv.classList.remove('hidden');
        }
      }, 10000);
    })();
  </script>
</div>

<style>
  .giscus-wrapper {
    min-height: 200px;
  }

  /* Giscus standard theme integration */
  :global(.giscus) {
    --giscus-background: transparent;
    --giscus-card-background: rgba(15, 23, 42, 0.7);
    --giscus-border: rgba(51, 65, 85, 0.5);
    --giscus-text-color: #e2e8f0;
    --giscus-link-color: #00f5ff;
    --giscus-font-family: 'Noto Sans SC', system-ui, sans-serif;
  }

  /* Light mode adjustments */
  :global(html:not(.dark) .giscus) {
    --giscus-card-background: rgba(255, 255, 255, 0.7);
    --giscus-border: rgba(226, 232, 240, 0.5);
    --giscus-text-color: #1e293b;
  }
</style>
