---
/**
 * Article Card Component
 * Displays title, description, tags, and date with hover glow effect
 */

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  cover?: string;
  url: string;
  category: 'tech' | 'gear';
  rating?: number;
  readingTime?: number;
}

const { title, description, pubDate, tags, cover, url, category, rating, readingTime } = Astro.props;

// Format date
const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="group relative flex flex-col h-full bg-white dark:bg-slate-900 rounded-xl overflow-hidden border border-slate-200 dark:border-slate-800 hover:border-l-4 hover:border-l-cyber-cyan transition-all duration-300 hover:shadow-lg hover:shadow-cyber-cyan/10">
  {/* Cover Image (optional) */}
  {cover && (
    <a href={url} class="block aspect-video overflow-hidden">
      <img
        src={cover}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      />
    </a>
  )}

  {/* Content Area */}
  <div class="flex flex-col flex-1 p-5">
    {/* Category & Tags */}
    <div class="flex flex-wrap gap-2 mb-3">
      <span class="text-xs font-medium px-2 py-1 rounded bg-cyber-cyan/10 text-cyber-cyan">
        {category === 'tech' ? 'Tech' : 'Gear'}
      </span>
      {tags.slice(0, 2).map((tag) => (
        <span class="text-xs px-2 py-1 rounded bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400">
          {tag}
        </span>
      ))}
    </div>

    {/* Title */}
    <a href={url} class="block">
      <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100 group-hover:text-cyber-cyan transition-colors line-clamp-2 mb-2">
        {title}
      </h3>
    </a>

    {/* Description */}
    <p class="text-sm text-slate-600 dark:text-slate-400 line-clamp-2 mb-4 flex-1">
      {description}
    </p>

    {/* Footer Info */}
    <div class="flex items-center justify-between mt-auto pt-4 border-t border-slate-100 dark:border-slate-800">
      {/* Date & Reading Time */}
      <div class="flex items-center gap-2 text-xs text-slate-500">
        <time datetime={pubDate.toISOString()}>
          {formattedDate}
        </time>
        {readingTime && (
          <>
            <span>·</span>
            <span>{readingTime} min read</span>
          </>
        )}
      </div>

      {/* Rating (gear category only) */}
      {rating && (
        <div class="flex items-center gap-1">
          {Array.from({ length: 5 }, (_, i) => (
            <span class={i < rating ? 'text-yellow-400' : 'text-slate-300 dark:text-slate-600'}>
              ★
            </span>
          ))}
        </div>
      )}
    </div>
  </div>
</article>

<style>
  /* Line clamp for description */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
