---
/**
 * Article Card Component
 * Displays title, description, tags, and date with hover glow effect
 */

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  cover?: string;
  url: string;
  category: 'tech' | 'gear' | 'essays' | 'life';
  rating?: number;
  readingTime?: number;
  index?: number;
}

const { title, description, pubDate, tags, cover, url, category, rating, readingTime, index = 0 } = Astro.props;

// Format date
const formattedDate = pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

// Category labels
const categoryLabels: Record<string, string> = {
  tech: '技术',
  gear: '装备',
  essays: '随笔',
  life: '生活',
};

// Category colors
const categoryColors: Record<string, string> = {
  tech: 'bg-cyber-cyan/10 text-cyber-cyan',
  gear: 'bg-electric-blue/10 text-electric-blue',
  essays: 'bg-cyber-purple/10 text-cyber-purple',
  life: 'bg-cyber-pink/10 text-cyber-pink',
};
---

<article
  class="group relative flex flex-col h-full bg-white dark:bg-slate-900 rounded-xl overflow-hidden border border-slate-200 dark:border-slate-800 hover:border-cyber-cyan/50 transition-all duration-300 hover:shadow-lg hover:shadow-cyber-cyan/10 card-hover opacity-0 translate-y-4"
  style={`animation-delay: ${index * 100}ms`}
  data-animate-card
>
  {/* Cover Image (optional) */}
  {cover && (
    <a href={url} class="block aspect-video overflow-hidden">
      <img
        src={cover}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      />
    </a>
  )}

  {/* Content Area */}
  <div class="flex flex-col flex-1 p-5">
    {/* Category & Tags */}
    <div class="flex flex-wrap gap-2 mb-3">
      <span class={`text-xs font-medium px-2 py-1 rounded ${categoryColors[category]}`}>
        {categoryLabels[category]}
      </span>
      {tags.slice(0, 2).map((tag) => (
        <span class="text-xs px-2 py-1 rounded bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400">
          {tag}
        </span>
      ))}
    </div>

    {/* Title */}
    <a href={url} class="block">
      <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100 group-hover:text-cyber-cyan transition-colors line-clamp-2 mb-2">
        {title}
      </h3>
    </a>

    {/* Description */}
    <p class="text-sm text-slate-600 dark:text-slate-400 line-clamp-2 mb-4 flex-1">
      {description}
    </p>

    {/* Footer Info */}
    <div class="flex items-center justify-between mt-auto pt-4 border-t border-slate-100 dark:border-slate-800">
      {/* Date & Reading Time */}
      <div class="flex items-center gap-2 text-xs text-slate-500">
        <time datetime={pubDate.toISOString()}>
          {formattedDate}
        </time>
        {readingTime && (
          <>
            <span>·</span>
            <span>{readingTime} 分钟阅读</span>
          </>
        )}
      </div>

      {/* Rating (gear category only) */}
      {rating && (
        <div class="flex items-center gap-1">
          {Array.from({ length: 5 }, (_, i) => (
            <span class={i < rating ? 'text-yellow-400' : 'text-slate-300 dark:text-slate-600'}>
              ★
            </span>
          ))}
        </div>
      )}
    </div>
  </div>
</article>

<style>
  /* Line clamp for description */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Card reveal animation */
  [data-animate-card] {
    animation: cardReveal 0.6s ease-out forwards;
  }

  @keyframes cardReveal {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  // Intersection Observer for card animations
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const card = entry.target as HTMLElement;
          card.style.opacity = '1';
          card.style.transform = 'translateY(0)';
          observer.unobserve(card);
        }
      });
    },
    { threshold: 0.1, rootMargin: '50px' }
  );

  document.querySelectorAll('[data-animate-card]').forEach((card) => {
    observer.observe(card);
  });
</script>
