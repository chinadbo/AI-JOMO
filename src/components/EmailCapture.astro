---
interface Props {
  variant?: 'inline' | 'boxed' | 'minimal';
  headline?: string;
  description?: string;
  buttonText?: string;
}

const {
  variant = 'boxed',
  headline = 'Get the AI Stack Decision Framework',
  description = 'A systematic approach to choosing the right AI tools — and avoiding $50k mistakes.',
  buttonText = 'Get the Free Framework'
} = Astro.props;

// Variant-specific classes
const variantClasses = {
  boxed: 'email-capture--boxed',
  inline: 'email-capture--inline',
  minimal: 'email-capture--minimal'
};
---

<div class={`email-capture ${variantClasses[variant]}`}>
  {headline && <h4 class="email-capture__headline">{headline}</h4>}
  {description && <p class="email-capture__description">{description}</p>}

  <form
    action="https://app.convertkit.com/forms/23340727/submissions"
    method="post"
    class="email-capture__form"
  >
    <input
      type="email"
      name="email_address"
      placeholder="Enter your email"
      required
      class="email-capture__input"
    />
    <button type="submit" class="email-capture__button">
      {buttonText}
    </button>
  </form>

  <p class="email-capture__privacy">No spam. Unsubscribe anytime. I respect your inbox.</p>
</div>
