---
/**
 * Related Posts Component
 * Shows related posts based on tags
 */

import { getCollection } from 'astro:content';

interface Props {
  currentPost: {
    id: string;
    data: {
      tags: string[];
      category?: string;
    };
  };
  currentLang: string;
  limit?: number;
}

const { currentPost, currentLang, limit = 3 } = Astro.props;

// Get all posts from the same collection
const collectionName = currentPost.id.split('/')[0] as 'tech' | 'gear' | 'essays' | 'life';
const allPosts = await getCollection(collectionName);

// Calculate similarity score based on shared tags
const relatedPosts = allPosts
  .filter((post) => post.id !== currentPost.id)
  .map((post) => {
    const sharedTags = post.data.tags.filter((tag) =>
      currentPost.data.tags.includes(tag)
    );
    return {
      post,
      score: sharedTags.length,
    };
  })
  .filter((item) => item.score > 0)
  .sort((a, b) => b.score - a.score)
  .slice(0, limit)
  .map((item) => item.post);

// Format date helper
function formatDate(date: Date) {
  return new Date(date).toLocaleDateString(currentLang === 'zh' ? 'zh-CN' : 'en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

{relatedPosts.length > 0 && (
  <section class="mt-12 pt-8 border-t border-slate-200 dark:border-slate-800">
    <h3 class="font-display text-lg font-semibold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
      <svg class="w-5 h-5 text-cyber-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
      </svg>
      {currentLang === 'zh' ? '相关文章' : 'Related Posts'}
    </h3>
    <div class="grid gap-4">
      {relatedPosts.map((post) => (
        <a
          href={`/${currentLang}/${collectionName}/${post.id}`}
          class="group flex items-start gap-4 p-4 rounded-lg bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 hover:border-cyber-cyan/50 transition-all card-hover"
        >
          <div class="flex-1 min-w-0">
            <h4 class="font-medium text-slate-900 dark:text-slate-100 group-hover:text-cyber-cyan transition-colors truncate">
              {post.data.title}
            </h4>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1 line-clamp-1">
              {post.data.description}
            </p>
            <div class="flex items-center gap-2 mt-2 text-xs text-slate-400">
              <time datetime={post.data.pubDate.toISOString()}>
                {formatDate(post.data.pubDate)}
              </time>
              <span>·</span>
              <span class="flex gap-1">
                {post.data.tags.slice(0, 2).map((tag) => (
                  <span class="text-cyber-cyan/70">#{tag}</span>
                ))}
              </span>
            </div>
          </div>
          <svg class="w-5 h-5 text-slate-400 group-hover:text-cyber-cyan transition-colors flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      ))}
    </div>
  </section>
)}
